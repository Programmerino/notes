      "vtp_script":"    SCMPBottomBar = (function () {\n      let newsletterName = \"Lunar\";\n      let newsletterId = 501957;\n      let url = \"https:\/\/www.scmp.com\/newsletters\"\n      let eventCategory = \"Bottom Bar\";\n\n      function getGAId() {\n        let gaId = typeof ga !== \"undefined\" ? ga.getAll()[0].get(\"clientId\") : \"\";\n        return gaId;\n      }\n\n      function getFormatedDate(date) {\n        var str = date.getFullYear();\n        str += \"-\" + (\"0\" + (date.getMonth() + 1)).slice(-2);\n        str += \"-\" + (\"0\" + date.getDate()).slice(-2);\n        str += \" \" + (\"0\" + date.getHours()).slice(-2);\n        str += \":\" + (\"0\" + date.getMinutes()).slice(-2);\n        return str;\n      }\n\n      function getDeviceCategory() {\n        return window.innerWidth \u003C= 1024 ? 'mobile' : 'desktop';\n      }\n\n      function getGaTrackingData() {\n        var gtmData = window.__APOLLO_STATE__['d8']['$ROOT_QUERY.gtmData'];\n        var userInfo = window.__APOLLO_STATE__['d8']['$ROOT_QUERY.userInfo'];\n        var urlParams = new URLSearchParams(window.location.search);\n        var gaTrackingData = {\n          from: 'scmp_web',\n          metrics: {\n            timestamp: getFormatedDate(new Date()),\n            country: (userInfo \u0026\u0026 userInfo.country) ? userInfo.country : '',\n            device_category: getDeviceCategory(),\n            event_category: 'optimize - ' + eventCategory,\n            client_id: getGAId(),\n            content_type: gtmData ? gtmData.contentType : '',\n            content: urlParams.get('utm_content'),\n            source: urlParams.get('utm_source'),\n            medium: urlParams.get('utm_medium'),\n            campaign: urlParams.get('utm_campaign'),\n            section: gtmData ? gtmData.sections : '',\n            url: window.location.href\n          },\n        };\n        console.log(gaTrackingData);\n        return gaTrackingData;\n      }\n\n      \/\/ JASONP Helper\n      var $jsonp = (function () {\n        var that = {};\n        that.send = function (src, options) {\n          var callback_name = options.callbackName || \"callback\",\n            on_success = options.onSuccess || function () {},\n            on_timeout = options.onTimeout || function () {},\n            timeout = options.timeout || 10; \/\/ sec(\n\n          var timeout_trigger = window.setTimeout(function () {\n            window[callback_name] = function () {};\n            on_timeout();\n          }, timeout * 1000);\n\n          window[callback_name] = function (data) {\n            window.clearTimeout(timeout_trigger);\n            on_success(data);\n          };\n\n          var script = document.createElement(\"script\");\n          script.type = \"text\/javascript\";\n          script.async = true;\n          script.src = src;\n\n          document.getElementsByTagName(\"head\")[0].appendChild(script);\n        };\n\n        return that;\n      })();\n\n      \/\/ UI control\n      function showSuccess() {\n        let content = document.querySelector(\n          \".overlay-bottom-bar .subscription-content\"\n        );\n        let success = document.querySelector(\".overlay-bottom-bar .success-msg\");\n\n        content.style.display = \"none\";\n        success.style.display = \"block\";\n      }\n\n      function showError() {\n        let content = document.querySelector(\n          \".overlay-bottom-bar .subscription-content\"\n        );\n        let error = document.querySelector(\".overlay-bottom-bar .error-msg\");\n\n        content.style.display = \"none\";\n        error.style.display = \"block\";\n      }\n\n      function showBottomBar() {\n        let bar = document.querySelector(\".overlay-bottom-bar\");\n        let content = document.querySelector(\n          \".overlay-bottom-bar .subscription-content\"\n        );\n        let error = document.querySelector(\".overlay-bottom-bar .error-msg\");\n        let success = document.querySelector(\".overlay-bottom-bar .success-msg\");\n\n        bar.classList.remove(\"hide\");\n        content.style.display = \"block\";\n        success.style.display = \"none\";\n        error.style.display = \"none\";\n\n        recordBarShown();\n        markShowDate();\n        trackEvent(eventCategory, eventCategory + \"\/Show\/\" + getBarShowTime(), newsletterName);\n      }\n\n      function dismissBottomBar() {\n        let bar = document.querySelector(\".overlay-bottom-bar\");\n        \/\/ bar.style.display = \"none\";\n        bar.classList.add(\"hide\");\n        trackEvent(eventCategory, eventCategory + \"\/Dismiss\", newsletterName);\n      }\n\n      function submitForm(e) {\n        console.log('submitForm')\n        e.preventDefault();\n        \/\/ Get email field\n        let email = document.getElementById(\"bottom-bar-email\").value;\n\n        \/\/ Fill in GA_CLIENID\n        document.getElementById('BOTTOM_BAR_GA_CLIENID').value = getGAId();\n        trackEvent(eventCategory, eventCategory + 'Sign up\/' + getBarShowTime(), newsletterName);\n        trackEvent(eventCategory, eventCategory + 'Sign up email', email);\n\n        var xhr = new XMLHttpRequest();\n        var url =\n          \"https:\/\/data.scmp.com\/api\/rest\/public\/v2\/newsletter\/subscribe.json\";\n        var data = {\n          id: newsletterId,\n          email: email,\n          entity_type: \"taxonomy_term\",\n          app_id: 325477\n        };\n        data['subscription-source'] = JSON.stringify(getGaTrackingData());\n\n        \/\/ var params = Object.keys(data)\n        \/\/     .map(key =\u003E `${key}=${data[key].toString()}`)\n        \/\/     .join(\"\u0026\");\n        var params = JSON.stringify(data);\n        xhr.open(\"POST\", url, true);\n\n        \/\/Send the proper header information along with the request\n        xhr.setRequestHeader(\"Content-type\", \"application\/json;charset=UTF-8\");\n\n        xhr.onreadystatechange = function () {\n          \/\/Call