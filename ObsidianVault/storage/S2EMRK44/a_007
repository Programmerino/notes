window.pn_janrain_is_loading = false;

function pn_janrain_render_screen( screen, stop_render ) {
	// If the HTML is already present, render the screen.

	// Analytics - Track Sign In from Comments
	if ( 'commentsSignIn' === screen ) {
		commentsOverride = 'CommentsSignIn';
		screen = "signIn";
	}

	var screen_elem = jQuery( '#' + screen );
	if ( screen_elem.length > 0 && screen_elem.text() ) {
		if ( ! stop_render ) {
			janrain.capture.ui.renderScreen( screen );
		}
		return;
	}

	// The screens are already being loaded.
	if ( window.pn_janrain_is_loading ) {
		return;
	}

	window.pn_janrain_is_loading = true;
	var data = {
		action: 'janrain_capture_sign_in',
	};

	// Fetch the HTML.
	jQuery.post( pn_janrain_vars.ajaxurl, data, function( response ) {
		window.pn_janrain_is_loading = false;

		// Remove the fake sign in screens.
		pn_janrain_remove_fake_screen( 'signIn' );
		pn_janrain_remove_fake_screen( 'returnSocial' );
		pn_janrain_remove_fake_screen( 'returnTraditional' );

		// Add the HTML to the page.
		jQuery( 'body' ).append( response );

		if ( ! stop_render ) {
			// Render the screen.
			if ( 'signIn' === screen ) {
				janrain.capture.ui.start();
			}
			janrain.capture.ui.renderScreen( screen );
		}
	} );
}

function pn_janrain_remove_fake_screen( screen ) {
	var elem = jQuery( '#' + screen );
	if ( elem.length > 0 && ! elem.text() ) {
		elem.remove();
	}
}
