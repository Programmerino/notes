function janrainCaptureWidgetOnLoadHandler() {
	if (_janrainCaptureWidgetOnLoadHandler) {
		_janrainCaptureWidgetOnLoadHandler();
	}

    var emailVerificationNotificationShown = false;
    var handleRegistrationSuccessResult = null;
	var refreshPageOnLogin = false;

    function getParameterByName(name) {
        name = name.replace(/[\[]/, "\\[").replace(/[\]]/, "\\]");
        var regex = new RegExp("[\\?&]" + name + "=([^&#]*)"),
            results = regex.exec(location.search);
        return results === null ? "" : decodeURIComponent(results[1].replace(/\+/g, " "));
    }
    var np_wp_ajax_url = ( typeof Postmedia != "undefined" )
        && Postmedia.hasOwnProperty( "Urls" ) && Postmedia.Urls.hasOwnProperty( "ajaxurl" )
        ? Postmedia.Urls.ajaxurl : "/wp-admin/admin-ajax.php";

    function handleCaptureLogout() {
        jQuery.ajax({
            type: 'get',
            url: np_wp_ajax_url,
            async: false,
            data: {
                'action':'npfp_ajax',
                'command':'janrain_capture_logout'
            },
            success: function(data) {
                var now = new Date;

                if (typeof FrontEndModules === 'undefined') {
                    Postmedia.Audience.logEvent("Sign Out", Postmedia.Audience.EventType.UserPreference, {});
                    Postmedia.Audience.setUserAttribute('Date of Last Log Out', now.toUTCString());
                }

                window.viafoura.$subscribe('logout', 'success', function (){
                    if( jQuery('#editProfile')[0] || jQuery('.my-account-page')[0] ){
                        window.location = 'https://' + document.location.host;
                    } else {
                        location.reload(true);
                    }
                });
            }
        });
    }

    function handleCaptureLogin(result) {
        // Call NP hook to login to Post Points, etc.
        if (result) {
            jQuery.ajax({
                type: 'get',
                dataType: 'text',
                url: np_wp_ajax_url,
                async: false,
                data: {
                    'action':'npfp_ajax',
                    'command':'janrain_capture_login',
                    'accessToken': result['accessToken'],
                    'uuid' : result['userData']['uuid']
                },
                success:function(data) {

                    if (typeof FrontEndModules === 'undefined') {
                        // Identity request object
                        Postmedia.Audience.identityRequest=Postmedia.Audience.identityRequest || {userIdentities:{}};

                        if (JSON.parse(localStorage.getItem('janrainCaptureProfileData')) != null) {
                        	Postmedia.Audience.identityRequest.userIdentities.customerid=JSON.parse(localStorage.getItem('janrainCaptureProfileData')).uuid;
                        	Postmedia.Audience.identityRequest.userIdentities.email=JSON.parse(localStorage.getItem('janrainCaptureProfileData')).email;
                        	Postmedia.Audience.identityRequest.onUserAlias = function(oldUser, newUser) {
                        		var oldUserAttributes = oldUser.getAllUserAttributes();
                                var newUserAttributes = newUser.getAllUserAttributes();

                                for (var userAttrKey in oldUserAttributes){
                                    newUser.setUserAttribute(userAttrKey, oldUserAttributes[userAttrKey]);
                        		}
                        	}
                        }

                        //On login result function
                        function onLoginResult(result) {
                            if (result.httpCode == 200) {
                                //proceed with login
                                //you can access the new/current mpid here
                                Postmedia.Audience.userId = result.body.mpid;
                            } else if (result.httpCode == -1) {
                                //browser has no coverage/HTTP request failed
                            } else if (result.httpCode == 429) {
                                //in rare circumstances, requests will be throttled and need to be retried
                            }
                        }
                        // When user logs in
                        Postmedia.Audience.login( Postmedia.Audience.identityRequest , onLoginResult );
                        if (localStorage.janrainLastAuthMethod!=undefined) {
                            Postmedia.Audience.logEvent("Sign In", Postmedia.Audience.EventType.UserPreference,{"Sign In Method":localStorage.janrainLastAuthMethod});
                        }
                        else {
                            Postmedia.Audience.logEvent("Sign In", Postmedia.Audience.EventType.UserPreference,{});
                        }

                        var now = new Date;
                        Postmedia.Audience.setUserAttribute('Date of Last Sign In', now.toUTCString());
                    }

                    var return_url = getParameterByName('returnurl');
                    var screenToRenderVal = getParameterByName( 'screenToRender' );
                    if ('' !== return_url) {
                        window.location = decodeURIComponent(return_url);
                    } else {
                        document.dispatchEvent(new CustomEvent('signin', {
                            bubbles: true,
                            detail: {
                                method: 'traditionalSignin'
                            }
                        }));

                        if ( refreshPageOnLogin ){
                            if ( screenToRenderVal === 'resetPasswordRequestCode' || screenToRenderVal === 'verifyEmail' ) {
                                location.href = location.protocol + '//' + location.hostname + location.pathname; // reloads page and removes the query string from the url path
                            } else {
                                location.reload(true); // Update buttons / points bar
                            }
                        }
                    }
                },
                error: function(error){
                    console.log("np_janrain_capture_login error:", error);
                }
            });
        }
    }

    function handleCaptureLoginFailed(result) {
        if (result.statusMessage == "accountDeactivated") {
            pn_janrain_render_screen('accountDeactivated');
        }
    }

    function handleRegistrationSuccess(result) {
        if (emailVerificationNotificationShown) {
            // We put this event here as per Kathleen's request. Hitting this screen means that the
			// user has in fact registered successfully.
            document.dispatchEvent(new CustomEvent('new-registration', {
				bubbles: true,
				detail: {
					tOf: 'true'
				}
			}));
            handleRegistrationSuccessResult = result;
        } else {
            handleCaptureLogin(result);
        }
    }

    function handleCaptureScreenShow(result) {
        var callFunction = true;
        var eventMsg = '';
        if ( 'undefined' !== typeof commentsOverride && 'CommentsSignIn'  === commentsOverride ) {
            var resultScreen = 'commentsSignIn';
        } else {
            var resultScreen = result.screen;
        }
        switch (resultScreen) {
            case 'commentsSignIn':
                eventMsg = 'Signin Comments Login';
                break;
            case 'signIn': //2.1
                eventMsg = 'Signin Meter Login';
                break;
            case 'returnSocial': //2.2
                eventMsg = 'Social Login Return User';
                break;
            case 'returnTraditional': //2.3
                var span = document.getElementById('traditionalWelcomeName');
                var name = janrain.capture.ui.getReturnExperienceData("displayName");
                if (span && name) {
                    span.innerHTML = "Welcome back, " + name + "!";
                }
                eventMsg = 'Traditional Login Return User';
                break;
            case 'socialRegistration':  //2.5
                eventMsg = 'Social Registration Meter Account Creation';
                break;
            case 'traditionalRegistration': //2.6
                eventMsg = 'Traditional Registration Meter Account Creation';
                break;
            case 'emailVerificationNotification': //2.7
                emailVerificationNotificationShown = true;
                eventMsg = 'Email Notification Meter Purchase Summary';
                break;
            case 'forgotPassword': //2.8
                eventMsg = 'Forgot Pwd Enter Email';
                break;
            case 'forgotPasswordSuccess': //2.9
                eventMsg = 'Forgot Pwd Success Email Sent';
                break;
            case 'verifyEmail': //2.12
                eventMsg = 'Verify Email';
                // We put this event here as per Kathleen's request. Hitting this screen means that the
				// user has in fact registered successfully.
                document.dispatchEvent(new CustomEvent('new-registration', {
					bubbles: true,
					detail: {
						tOf: 'true'
					}
				}));
                break;
            case 'resendVerificationSuccess': //2.13
                eventMsg = 'Resend Verification Success';
                break;
            case 'verifyEmailSuccess': //2.14.
                eventMsg = 'Verify Email Success';
                break;
            case 'resetPassword':  //2.15
                eventMsg = 'Reset Pwd New Password';
                break;
            case 'resetPasswordSuccess': //2.16
                eventMsg = 'Reset Pwd Success Pwd Changed';
                break;
            case 'resetPasswordRequestCode': //2.17
                eventMsg = 'Reset Pwd Request Code';
                break;
            case 'resetPasswordRequestCodeSuccess': //2.18
                eventMsg = 'Reset Pwd Request Code Success';
                break;
            case 'editProfile': //2.19
                eventMsg = 'Edit Profile';
                break;
            case 'changePassword': //2.20
                eventMsg = 'Change Pwd';
                break;
            case 'confirmAccountDeactivation': //2.21
                eventMsg = 'Confirm Account Deactivation';
                break;
            case 'accountDeactivated': //2.4
            case 'mergeAccounts': //2.10
            case 'traditionalAuthenticateMerge': //2.11
            case 'reactivateAccount':
            case 'reactivateAccountSuccess':
            case 'emailVerificationRequired':
                eventMsg = 'Email Verification Required';
                break;
            default:
                callFunction = false;
                break;
        }

        if (callFunction){
            if (typeof FrontEndModules === 'undefined') {
                Postmedia.Analytics.ModelScreen('Janrain', eventMsg);
            } else {
                ModelScreenAnalytics('Janrain', eventMsg);
            }
        }
    }

    function handleCaptureSessionFound(result) {
        var return_url = getParameterByName('returnurl');
        if ('' !== return_url) {
            window.location = decodeURIComponent(return_url);
        }
    }

    /* Social login button click tracking
     *
     * For more information, please go to http://developers.janrain.com/overview/integrations/blueprint-integrations/omniture-sitecatalyst/#overview
     */
    janrain.events.onProviderLoginStart.addHandler(function(result){
        var callFunction = true;
        var provider = null;

        switch( result.provider ) {
            case 'facebook':
                provider = Postmedia.Analytics.SocialTypes.FACEBOOK_LOGIN;
                break;
            case 'twitter':
                provider = Postmedia.Analytics.SocialTypes.TWITTER_LOGIN;
                break;
            case 'googleplus':
                provider = Postmedia.Analytics.SocialTypes.GOOGLE_LOGIN;
                break;
            case 'yahoo':
                provider = Postmedia.Analytics.SocialTypes.YAHOO_LOGIN;
                break;
            case 'linkedin':
                provider = Postmedia.Analytics.SocialTypes.LINKEDIN_LOGIN;
                break;
            case 'openid':
                provider = Postmedia.Analytics.SocialTypes.OPENID_LOGIN;
                break;
            default :
                callFunction = false;
                break;
        }

        if (callFunction){
            Postmedia.Analytics.SocialLogin(provider);
        }
    });

    function handleModalReady() {
        var screenToRender = getParameterByName('screenToRender');
        if ( screenToRender ) {
            pn_janrain_render_screen( screenToRender );
        } else if ( getParameterByName('layer') == 'true' && !janrain.capture.ui.hasActiveSession() )
        {
            pn_janrain_render_screen( 'signIn' );
        }
    }

    function handleModalClose() {
        if (emailVerificationNotificationShown) {
            emailVerificationNotificationShown = false;
            handleCaptureLogin(handleRegistrationSuccessResult);
        }
    }

    function handleonAccountDeactivateSuccess(result) {
        if(result.status == "success") {
            document.getElementById("editProfile").style.display = 'none';
            janrain.capture.ui.modal.close();
            janrain.capture.ui.endCaptureSession();
            window.location = '/category/news/?screenToRender=accountDeactivated';
        }
    }

	function handleonCaptureAccessDenied(result) {
		 if(localStorage && localStorage.getItem("janrainCaptureToken")){
            janrain.capture.ui.createCaptureSession(localStorage.getItem("janrainCaptureToken"));
        }else{
        	window.location = 'https://' + document.location.host
                + '/?layer=true&returnurl=' + encodeURIComponent( document.location.href );
        }
	}

	function handleOnCaptureFederateNoLogin(){
		if ( document.location.host.indexOf( 'pages' ) < 0 ) {
			refreshPageOnLogin = true;
		}
	}

	function handleOnModalOpen(){
		if ( window.innerWidth < 768 ){
			document.getElementById('page').style.display = 'none';
		}
	}

	function handleOnModalClose(){
		if ( window.innerWidth < 768 ){
			document.getElementById('page').style.display = 'block';
		}
	}

    janrain.events.onCaptureSessionEnded.addHandler(handleCaptureLogout);
    janrain.events.onCaptureLoginSuccess.addHandler(handleCaptureLogin);
    janrain.events.onCaptureLoginFailed.addHandler(handleCaptureLoginFailed);
    janrain.events.onCaptureSessionFound.addHandler(handleCaptureSessionFound);
    janrain.events.onCaptureRegistrationSuccess.addHandler(handleRegistrationSuccess);
    janrain.events.onCaptureScreenShow.addHandler(handleCaptureScreenShow);
    janrain.events.onCaptureModalReady.addHandler(handleModalReady);
    janrain.events.onModalClose.addHandler(handleModalClose);
    janrain.events.onCaptureAccountDeactivateSuccess.addHandler(handleonAccountDeactivateSuccess);
	janrain.events.onCaptureAccessDenied.addHandler(handleonCaptureAccessDenied);
	janrain.events.onCaptureFederateNoLogin.addHandler(handleOnCaptureFederateNoLogin);
	janrain.events.onModalOpen.addHandler(handleOnModalOpen);
	janrain.events.onModalClose.addHandler(handleOnModalClose);

