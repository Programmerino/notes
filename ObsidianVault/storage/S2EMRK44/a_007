			if (localStorage.janrainLastAuthMethod!=undefined) {
				setUserAttributeAnalytics( 'Registration Method', localStorage.janrainLastAuthMethod );
			}
			var now = new Date;
			setUserAttributeAnalytics( 'Date of Last Sign In', now.toUTCString() );
			signinFlagSuccess = false;
		}
	}
}
