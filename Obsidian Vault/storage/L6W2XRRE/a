}

#candidatebox .hoverfilter {
 position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 80, 116, .9);
  color: #fff;
  visibility: hidden;
  opacity: 0;
}

#candidatebox .hoverfilter p {
	
	line-height: 1.3;
	font-weight: normal;
